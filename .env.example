# --------------------------------------------------------------------------
# Manchester United @ World Cup - environment configuration
# --------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you want to use.
# Everything is OPTIONAL - the app ships with a free public data source
# (ESPN) and will work out of the box with no configuration.
# --------------------------------------------------------------------------

# --- API-Football (https://www.api-football.com) ----------------------------
# Not yet wired in — currently a stub.  ESPN is the active data source and
# works without any configuration.  Uncomment if you implement the adapter.
# API_FOOTBALL_KEY=your_api_key_here
# API_FOOTBALL_HOST=v3.football.api-sports.io
